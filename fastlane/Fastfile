default_platform(:ios)

# Builds the app and uploads the binary to App Store Connect / TestFlight.
#
# Authentication uses an App Store Connect API key (no Apple ID / 2FA needed),
# read from environment variables — see .github/workflows/deploy-appstore.yml
# and docs/DEPLOY.md. The distribution certificate must already be in the
# keychain (the workflow imports it before calling this lane).
platform :ios do
  desc "Build and upload to App Store Connect (lands in TestFlight)"
  lane :release do
    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_content: ENV.fetch("ASC_KEY_CONTENT"),
      is_key_content_base64: true,
      in_house: false
    )

    # Use the CI run number as the build number so every upload is unique.
    increment_build_number(
      xcodeproj: "YesNo.xcodeproj",
      build_number: ENV["GITHUB_RUN_NUMBER"] || Time.now.strftime("%Y%m%d%H%M")
    )

    build_app(
      project: "YesNo.xcodeproj",
      scheme: "YesNo",
      configuration: "Release",
      export_method: "app-store",
      # Let Xcode create/refresh the distribution profile via the API key.
      xcargs: "-allowProvisioningUpdates DEVELOPMENT_TEAM=#{ENV.fetch('DEVELOPMENT_TEAM')}",
      export_options: {
        teamID: ENV.fetch("DEVELOPMENT_TEAM"),
        signingStyle: "automatic"
      }
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end
